{
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "mcpServers": {
    "unityMCP": {
      "url": "http://localhost:8080/mcp"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-scene-edit.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-meta-edit.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": ".claude/hooks/guard-editor-runtime.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/gateguard.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": ".claude/hooks/guard-project-config.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-projectsettings.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": ".claude/hooks/bash-gate.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/track-reads.sh",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/warn-serialization.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/warn-filename.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": ".claude/hooks/warn-platform-defines.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/quality-gate.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/track-edits.sh",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": ".claude/hooks/suggest-verify.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-commit.sh",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": ".claude/hooks/build-analyze.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/cost-tracker.sh",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": ".claude/hooks/instinct-capture.sh",
            "timeout": 2000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-compact.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-restore.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-validate.sh",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": ".claude/hooks/session-save.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/auto-learn.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": ".claude/hooks/instinct-distill.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": ".claude/hooks/notify.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
